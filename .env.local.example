# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=votre_cle_secrete_turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=votre_cle_publique_turnstile

# Redirection apres captcha
NEXT_PUBLIC_REDIRECT_URL=https://linktr.ee/votre_compte
NEXT_PUBLIC_SITE_URL=https://votre-site.vercel.app

# Dashboard admin
ADMIN_KEY=votre_mot_de_passe_super_secret

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABCDEFxxxxxx
TELEGRAM_CHAT_ID=votre_chat_id

# Spike alert threshold
SPIKE_THRESHOLD=20

# Upstash Redis (remplace @vercel/kv)
# vercel.com > Integrations > Upstash Redis
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=votre_token_upstash
