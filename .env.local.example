# ============================================
# Cloudflare Turnstile
# dash.cloudflare.com → Zero Trust → Turnstile
# ============================================
TURNSTILE_SECRET_KEY=votre_cle_secrete_turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=votre_cle_publique_turnstile

# ============================================
# Redirection après captcha validé
# ============================================
NEXT_PUBLIC_REDIRECT_URL=https://linktr.ee/votre_compte

# ============================================
# Dashboard admin — accès via /admin?key=...
# ============================================
ADMIN_KEY=votre_mot_de_passe_super_secret
NEXT_PUBLIC_ADMIN_KEY=votre_mot_de_passe_super_secret

# ============================================
# Vercel KV (Redis) — injectés automatiquement
# par Vercel après création du KV store
# ============================================
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
